# Keep Lambda Docker build contexts small and stable.
node_modules
**/node_modules
package-lock.json
**/package-lock.json
.git
.gitignore
test
**/test
*.test.js
# The local container E2E invokes this internal harness from the AgentCore
# image. Keep its dependency closure while excluding the rest of the tests.
!agentcore/test/
agentcore/test/*
!agentcore/test/local-e2e-config.js
!agentcore/test/local-e2e-harness.mjs
!agentcore/test/helpers/
agentcore/test/helpers/*
!agentcore/test/helpers/v2-table.js
.dockerignore
# Lambda packaging outputs — written DURING terraform apply by the
# terraform-aws-modules/lambda build commands. Tarring them while they are
# rewritten corrupts the docker build context (archive/tar: invalid tar
# header) and stalls parallel image builds. The agentcore image copies only
# agentcore/** and shared/** — never .build artifacts.
.build
**/.build
builds
**/builds
