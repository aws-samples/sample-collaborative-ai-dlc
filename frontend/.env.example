# AWS Configuration
VITE_AWS_REGION=us-east-1
VITE_AWS_USER_POOL_ID=your-user-pool-id
VITE_AWS_USER_POOL_CLIENT_ID=your-user-pool-client-id

# API Configuration — routed through CloudFront so the origin secret header
# is injected; direct calls to execute-api.amazonaws.com are blocked by the
# API Gateway resource policy. Get domain via:
#   cd environments/dev && terraform output -raw cloudfront_domain_name
VITE_API_BASE_URL=https://your-cloudfront-domain.cloudfront.net/api

# WebSocket Configuration (get from: cd environments/dev && terraform output websocket_api_endpoint)
VITE_WEBSOCKET_URL=wss://your-ws-api-id.execute-api.us-east-1.amazonaws.com/dev

# Yjs Server Configuration (via CloudFront; get domain from: cd environments/dev && terraform output cloudfront_distribution_domain)
VITE_YJS_SERVER_URL=wss://your-cloudfront-domain.cloudfront.net/yjs

# Environment
VITE_ENVIRONMENT=development