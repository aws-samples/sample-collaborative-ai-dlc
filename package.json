{
  "name": "sample-collaborative-ai-dlc",
  "version": "2.0.0",
  "private": true,
  "workspaces": [
    "lambda/agentcore",
    "lambda/agents",
    "lambda/building-blocks",
    "lambda/code-files",
    "lambda/cognito-users",
    "lambda/discussions",
    "lambda/general-info",
    "lambda/github",
    "lambda/intents",
    "lambda/gitlab",
    "lambda/migrate-tracker-fields",
    "lambda/seed-blocks",
    "lambda/projects",
    "lambda/purge-neptune",
    "lambda/questions",
    "lambda/requirements",
    "lambda/reviews",
    "lambda/sprint-graph",
    "lambda/sprints",
    "lambda/tasks",
    "lambda/v2-orchestrator",
    "lambda/timeline-events",
    "lambda/trackers",
    "lambda/user-stories",
    "lambda/users",
    "lambda/workflows",
    "lambda/ws-authorizer",
    "lambda/ws-connection",
    "lambda/ws-message"
  ],
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "secretlint": "secretlint --secretlintignore .gitignore '**/*'",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "audit:prod:frontend": "npm --prefix frontend audit --omit=dev --audit-level=high",
    "audit:prod:all": "npm run audit:prod && npm run audit:prod:frontend",
    "typecheck:frontend": "npm --prefix frontend run typecheck",
    "release:prepare": "node scripts/release.mjs prepare",
    "release:check": "node scripts/release.mjs check",
    "test:release": "node --test scripts/test/*.test.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@aws-sdk/client-apigatewaymanagementapi": "^3.1085.0",
    "@aws-sdk/client-dynamodb": "^3.1085.0",
    "@aws-sdk/client-lambda": "^3.1085.0",
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/client-secrets-manager": "^3.1085.0",
    "@aws-sdk/client-ssm": "^3.1085.0",
    "@aws-sdk/credential-providers": "^3.1081.0",
    "@aws-sdk/lib-dynamodb": "^3.1085.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "@secretlint/secretlint-rule-preset-recommend": "13.0.2",
    "@smithy/config-resolver": "^4.6.8",
    "@smithy/node-config-provider": "^3.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "aws-sdk-client-mock": "^4.1.0",
    "aws-sdk-client-mock-vitest": "^7.1.0",
    "esbuild": "^0.28.1",
    "gremlin": "^3.8.1",
    "gremlin-aws-sigv4": "^3.6.1",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "neptune-lambda-client": "^3.0.0",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "secretlint": "13.0.2",
    "testcontainers": "^11.0.0",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "@aws/durable-execution-sdk-js-testing": {
      "@aws/durable-execution-sdk-js": "^2.0.0"
    },
    "archiver-utils": {
      "glob": "^13.0.6"
    },
    "uuid": "^11.1.1"
  }
}
