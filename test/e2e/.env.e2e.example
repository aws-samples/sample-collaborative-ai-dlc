# Copy to test/e2e/.env.e2e (gitignored) and fill in.
# Cognito pool/client/API/region are read from frontend/.env automatically.
E2E_USERNAME=you@example.com
E2E_PASSWORD=your-cognito-password
# Frontend URL for the Playwright observer (CloudFront URL, no trailing slash)
E2E_FRONTEND_URL=https://XXXXXXXXXXXXXX.cloudfront.net
# Comma-separated owner/repo list. First entry becomes the primary repo.
E2E_REPOS=GITHUB_USER/retail-store-ui,GITHUB_USER/retail-store-cart,GITHUB_USER/retail-store-catalog
# Agent CLI configured in SSM (kiro|claude|opencode)
E2E_CLI=kiro
E2E_BASE_BRANCH=main
# Optional: read-only PAT used only to verify which repos changed (commits ahead of base)
E2E_GITHUB_TOKEN=
# Optional: close created PRs + delete branches after the run (never merges)
E2E_TEARDOWN=false
# Per-phase wait budget (ms). Default 30 min.
E2E_TIMEOUT_MS=1800000
# Optional override for the feature description the agents implement.
E2E_DESCRIPTION=
